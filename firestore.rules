rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function campaign(campaignId) {
      return get(/databases/$(database)/documents/campaigns/$(campaignId)).data;
    }

    function isHost(campaignId) {
      return isSignedIn() && campaign(campaignId).hostUid == request.auth.uid;
    }

    function isMember(campaignId) {
      return isSignedIn() && request.auth.uid in campaign(campaignId).playerUids;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /campaigns/{campaignId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.playerUids;
      allow create: if isSignedIn() && request.resource.data.hostUid == request.auth.uid
                    && request.auth.uid in request.resource.data.playerUids;
      allow update: if isSignedIn() && resource.data.hostUid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.hostUid == request.auth.uid;

      match /members/{uid} {
        allow read: if isMember(campaignId);
        allow write: if isHost(campaignId) || isSelf(uid);
      }

      match /characters/{characterId} {
        allow read: if isMember(campaignId);
        allow create: if isMember(campaignId)
                      && request.resource.data.ownerUid == request.auth.uid;
        allow update, delete: if isSignedIn()
                              && (resource.data.ownerUid == request.auth.uid || isHost(campaignId));
      }

      match /npcs/{npcId} {
        allow read: if isMember(campaignId)
                    && (isHost(campaignId) || resource.data.visibleToPlayers == true);
        allow write: if isHost(campaignId);
      }

      match /sessions/{sessionId} {
        allow read: if isMember(campaignId);
        allow write: if isHost(campaignId);

        match /messages/{messageId} {
          allow read: if isMember(campaignId);
          allow create: if isMember(campaignId)
                        && request.resource.data.authorUid == request.auth.uid;
          allow update, delete: if isSignedIn()
                                && (resource.data.authorUid == request.auth.uid || isHost(campaignId));
        }
      }

      match /state/{stateDoc} {
        allow read: if isMember(campaignId);
        allow write: if isHost(campaignId);
      }

      match /saves/{saveId} {
        allow read: if isMember(campaignId);
        allow write: if isHost(campaignId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
