# Firebase Web SDK config (public — safe to embed in the bundle).
# Copy to .env.local and fill from Firebase Console → Project Settings → Your apps.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# API base URL.
# - Empty in production on Vercel (frontend & API on same domain).
# - In local dev, point at your local Vercel dev or a deployed URL:
#   VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=

# Optional: point Auth + Firestore at the local emulator suite.
VITE_USE_EMULATORS=false
